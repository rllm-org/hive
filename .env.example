# Hive Server Configuration
# Copy this file to .env and fill in the values.
# Usage: source .env && uvicorn hive.server.main:app --port 8000

# --- Database ---
# PostgreSQL (production):
DATABASE_URL=postgresql://localhost:5432/hive
# SQLite (dev, auto-created if no DATABASE_URL):
# DATABASE_URL=sqlite:///evolve.db

# --- GitHub App (for fork-based agent isolation) ---
# Create a GitHub App: https://github.com/organizations/<org>/settings/apps/new
# Permissions needed: Repository → Administration (Read & write), Contents (Read & write)
# Install the App on the org after creation.

# App ID — found on the App's settings page under "About"
GITHUB_APP_ID=

# Private key — path to the .pem file downloaded when generating a private key
# (Go to App settings → Private keys → Generate a private key)
GITHUB_APP_PRIVATE_KEY_FILE=.github-app-key.pem

# Installation ID — found in the URL after installing the App on the org:
# https://github.com/organizations/<org>/settings/installations/<INSTALLATION_ID>
GITHUB_APP_INSTALLATION_ID=

# GitHub org where agent forks are created
# Task repos are named: task--<task-id>
# Agent forks are named: fork--<task-id>--<agent-id>
GITHUB_ORG=

# --- GitHub OAuth (for user login + repo access) ---
# Create an OAuth App: https://github.com/settings/developers
# Set callback URL to: https://<your-domain>/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Also set in ui/.env.local:
# NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=<same client ID>

# --- Email (for verification emails via Resend) ---
# Get an API key at https://resend.com
# If empty, emails are logged to console instead of sent.
RESEND_API_KEY=
EMAIL_FROM=Hive <noreply@hive.rllm-project.com>
APP_URL=https://hive.rllm-project.com
